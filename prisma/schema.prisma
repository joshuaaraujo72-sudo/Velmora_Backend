generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  BUYER
  SELLER
  ADMIN
}

enum StoreStatus {
  DRAFT
  ACTIVE
  SUSPENDED
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(BUYER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store  Store?
  orders Order[]
  favorites FavoriteProduct[]
}

model Store {
  id          String      @id @default(uuid())
  ownerId     String      @unique
  name        String
  description String?
  category    String?
  storeType   String?
  logoUrl     String?
  bannerUrl   String?
  website     String?
  instagram   String?
  phone       String?
  address     String?
  status      StoreStatus @default(ACTIVE)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  owner    User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  products Product[]
  metrics  StoreMetric[]
  items    OrderItem[]

  @@index([status])
  @@index([category])
}

model Product {
  id          String   @id @default(uuid())
  storeId     String
  name        String
  category    String?
  price       Decimal  @db.Decimal(10, 2)
  stock       Int      @default(0)
  description String?
  imageUrl    String?
  sizes       Json?
  colors      Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  items OrderItem[]
  favorites FavoriteProduct[]

  @@index([storeId])
  @@index([category])
  @@index([isActive])
}

model FavoriteProduct {
  id        String   @id @default(uuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
  @@index([productId])
}

model Order {
  id        String   @id @default(uuid())
  buyerId   String
  status    String   @default("PENDING")
  total     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyer User        @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  items OrderItem[]

  @@index([buyerId])
  @@index([status])
}

model OrderItem {
  id            String  @id @default(uuid())
  orderId       String
  productId     String
  storeId       String
  quantity      Int
  unitPrice     Decimal @db.Decimal(10, 2)
  selectedSize  String?
  selectedColor String?

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
  @@index([storeId])
}

model StoreMetric {
  id        String   @id @default(uuid())
  storeId   String
  type      String
  value     Int      @default(1)
  createdAt DateTime @default(now())

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
  @@index([type])
  @@index([createdAt])
}

model Event {
  id          String   @id @default(uuid())
  title       String
  description String
  type        String   @default("EVENTO")
  storeName   String?
  imageUrl    String?
  startsAt    DateTime
  endsAt      DateTime
  isFeatured  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([isFeatured])
  @@index([startsAt])
}

model Discount {
  id          String   @id @default(uuid())
  storeName   String
  title       String
  description String
  category    String
  validUntil  String?
  imageUrl    String?
  storeUrl    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([isActive])
}
